{
  "name": "haven",
  "version": "0.0.0",
  "private": true,
  "description": "Household dashboard + second-brain. Eink wall + phone PWA.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter='@haven/backend' --filter='@haven/dashboard' dev",
    "build": "bun run --filter='./apps/*' build",
    "check": "bun run --filter='./apps/*' check",
    "mcp": "bun run --filter='@haven/mcp' start",
    "clean": "rm -rf apps/*/.svelte-kit apps/*/dist apps/*/build node_modules apps/*/node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
