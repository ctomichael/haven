# Copy to .env and adjust for your local setup.
# .env is gitignored; .env.example is the documented template.

# Postgres connection string used by the backend.
# Matches the docker-compose.yml defaults.
DATABASE_URL=postgres://haven:haven@localhost:5432/haven

# Backend HTTP port (Hono on Bun).
PORT=8080

# Dashboard dev server reads this when proxying /api/* — leave commented to use the default.
# HAVEN_BACKEND_URL=http://localhost:8080

# Town for /api/weather (MetService publicData). Inserted verbatim into the
# endpoint name, so use MetService's casing (e.g. Queenstown, Wellington).
# HAVEN_WEATHER_TOWN=Queenstown

# Home Assistant read proxy (/api/ha/*). Token is a Long-Lived Access Token
# created in HA (Profile → Security → Long-lived access tokens). Backend-only;
# never exposed to the browser. Leave unset to disable HA widgets.
# HAVEN_HA_URL=http://192.168.1.130:8123
# HAVEN_HA_TOKEN=eyJ...your-long-lived-token...
