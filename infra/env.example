# Haven — runtime environment template.
#
# Installed to /etc/haven/.env by infra/install.sh (mode 0640, owned by
# root:haven). NEVER commit a filled-in copy of this file to the repo.
#
# Port assignments live in the systemd units (haven-backend → 8080,
# haven-dashboard → 3000) — don't set PORT here or it overrides both.

# --- Caddy / TLS ----------------------------------------------------------
# Skip these if you're running behind an existing reverse proxy
# (HAVEN_INSTALL_CADDY=no when running install.sh).
#
# Domain the dashboard is reachable at. Used by the bundled Caddyfile
# template AND by SvelteKit's CSRF check (ORIGIN, below).
CADDY_DOMAIN=haven.yourdomain.com

# Cloudflare API token with Zone:Read + DNS:Edit on the relevant zone.
# Only used when Caddy issues the cert itself via DNS-01.
CF_API_TOKEN=cf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Dashboard (SvelteKit SSR) --------------------------------------------
# ORIGIN is required for adapter-node when behind a reverse proxy — it's
# how SvelteKit checks the Origin header on POST/form requests. Match
# this to the public URL.
ORIGIN=https://haven.yourdomain.com

# --- Database -------------------------------------------------------------
# In production the haven user reads this. Change from the dev default
# before exposing the box.
DATABASE_URL=postgres://haven:haven@localhost:5432/haven

# --- Voice transcription (whisper.cpp) ------------------------------------
# Defaults work after `infra/install.sh` finishes.
WHISPER_BIN=/usr/local/bin/whisper-cli
WHISPER_MODEL=/opt/whisper-models/ggml-base.en.bin
FFMPEG_BIN=/usr/bin/ffmpeg

# --- Attachments ----------------------------------------------------------
HAVEN_ATTACHMENTS_DIR=/var/haven/attachments

# --- Deploy trigger -------------------------------------------------------
# Bearer token guarding POST /api/deploy. When set, hitting the endpoint
# touches /var/haven/.deploy-pending which a systemd path unit watches —
# the watcher fires haven-autopull.service immediately. Generate with:
#   openssl rand -hex 32
# Endpoint is reachable via the public URL, so the token MUST be strong.
HAVEN_DEPLOY_TOKEN=

# Where the deploy-trigger sentinel lives. Default matches what the
# bundled systemd path unit watches; only change if you also change the
# path unit.
HAVEN_DEPLOY_TRIGGER_PATH=/var/haven/.deploy-pending

# --- Hermes (reference only — Haven itself doesn't read these) ------------
# HERMES_API_KEY=...
# HERMES_WORKDIR=/opt/hermes

# --- Home Assistant (future) ----------------------------------------------
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=...

# --- Google Calendar (future) ---------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GOOGLE_OAUTH_REFRESH_TOKEN=...
