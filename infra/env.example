# Haven — runtime environment template.
#
# Installed to /etc/haven/.env by infra/install.sh (mode 0640, owned by
# root:haven). NEVER commit a filled-in copy of this file to the repo.

# --- Caddy / TLS ----------------------------------------------------------
# Domain the dashboard is reachable at. The Caddyfile reads this.
CADDY_DOMAIN=haven.yourdomain.com

# Cloudflare API token with Zone:Read + DNS:Edit on the relevant zone.
# Required for DNS-01 challenge. Generate at
# https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=cf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database -------------------------------------------------------------
# In production the haven user reads this. The Postgres password should be
# strong — change from the dev default before exposing the box.
DATABASE_URL=postgres://haven:haven@localhost:5432/haven

# --- Backend --------------------------------------------------------------
PORT=8080

# --- Dashboard ------------------------------------------------------------
# HOST and PORT for the SvelteKit SSR are set in the systemd unit.

# --- Voice transcription (whisper.cpp) ------------------------------------
# Defaults work after `infra/install.sh` finishes.
WHISPER_BIN=/usr/local/bin/whisper-cli
WHISPER_MODEL=/opt/whisper-models/ggml-base.en.bin
FFMPEG_BIN=/usr/bin/ffmpeg

# --- Attachments ----------------------------------------------------------
HAVEN_ATTACHMENTS_DIR=/var/haven/attachments

# --- Hermes (reference only — Haven itself doesn't read these) ------------
# HERMES_API_KEY=...
# HERMES_WORKDIR=/opt/hermes

# --- Home Assistant (future) ----------------------------------------------
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=...

# --- Google Calendar (future) ---------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GOOGLE_OAUTH_REFRESH_TOKEN=...
